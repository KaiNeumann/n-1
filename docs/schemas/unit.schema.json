{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/KaiNeumann/n-1/main/docs/schemas/unit.schema.json",
  "title": "n-1 Unit (Portion) row",
  "description": "JSON Schema for one portion row in knowledge/units/portions.jsonl.",
  "type": "object",
  "required": ["id", "schema_version", "source", "name", "weight_grams"],
  "properties": {
    "id":            { "$ref": "_common.json#/$defs/id" },
    "schema_version": { "$ref": "_common.json#/$defs/schema_version" },
    "source":        { "$ref": "_common.json#/$defs/source" },

    "name":         { "type": "string", "minLength": 1, "description": "Lowercased German portion name (e.g. 'scheibe')." },
    "weight_grams": { "type": ["number", "null"], "minimum": 0, "description": "Default weight in grams (or ml for liquids). 100 = variable/unspecified." }
  },
  "additionalProperties": true
}
