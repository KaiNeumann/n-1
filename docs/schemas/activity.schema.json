{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/KaiNeumann/n-1/main/docs/schemas/activity.schema.json",
  "title": "n-1 Activity row",
  "description": "JSON Schema for one activity row in knowledge/activities/activities.jsonl.",
  "type": "object",
  "required": ["id", "schema_version", "source", "name", "name_de", "category", "calories_per_hour"],
  "properties": {
    "id":            { "$ref": "_common.json#/$defs/id" },
    "schema_version": { "$ref": "_common.json#/$defs/schema_version" },
    "source":        { "$ref": "_common.json#/$defs/source" },

    "name":     { "type": "string", "minLength": 1 },
    "name_de":  { "type": "string", "minLength": 1 },
    "category": { "$ref": "#/$defs/category" },
    "description": { "type": "string" },
    "calories_per_hour": { "type": "number", "minimum": 0 },

    "intensity_range": {
      "type": "array",
      "items": { "$ref": "#/$defs/intensity" }
    },
    "effects": { "type": "array", "items": { "$ref": "#/$defs/activity_effect" } },
    "sources": { "type": "array", "items": { "$ref": "_common.json#/$defs/data_source" } }
  },
  "additionalProperties": true,

  "$defs": {
    "category": {
      "enum": [
        "cardio", "strength", "flexibility", "sports", "high_intensity",
        "walking", "daily_living", "sedentary", "household",
        "transportation", "recreation", "work"
      ]
    },
    "intensity": {
      "enum": ["rest", "low", "moderate", "high", "maximal"]
    },
    "activity_effect": {
      "type": "object",
      "required": ["target_type", "target_name", "direction"],
      "properties": {
        "target_type":         { "enum": ["biomarker", "vital_sign", "symptom"] },
        "target_name":         { "type": "string" },
        "direction":           { "enum": ["increase", "decrease", "variable", "none"] },
        "mechanism":           { "type": "string" },
        "duration_dependent":  { "type": "boolean" },
        "intensity_dependent": { "type": "boolean" },
        "acute_effect":        { "type": ["string", "null"] },
        "chronic_effect":      { "type": ["string", "null"] },
        "sources":             { "type": "array", "items": { "$ref": "_common.json#/$defs/data_source" } }
      },
      "additionalProperties": true
    }
  }
}
